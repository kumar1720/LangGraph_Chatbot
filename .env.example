# Unified Server Settings
API_V1_STR=/api/v1
PROJECT_NAME="AI Unified Chatbot"
BACKEND_CORS_ORIGINS=["*"]

# Security Configuration
SECRET_KEY=your_secure_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Persistent MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Google Gemini API Configuration (Google AI Studio Free Tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Cloud Cluster Configuration (Free Tier Vector Storage)
QDRANT_HOST=your_qdrant_cloud_host_here.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# Redis Configuration (Upstash Free Tier)
REDIS_URL=rediss://default:your_redis_password_here@your_redis_host_here.upstash.io:6379

# Optional LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_langsmith_project_name_here